<style>
    .hero-image {
        animation: heroZoom 8s ease-out forwards;
    }

    @keyframes heroZoom {
        from {
            transform: scale(1.12);
        }

        to {
            transform: scale(1);
        }
    }

    .hero-title,
    .hero-title-2 {
        opacity: 0;

        filter: blur(8px);

        clip-path: inset(0 100% 0 0);

        animation: revealName 1.5s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
    }

    .hero-title {
        animation-delay: 0.5s;
    }

    .hero-title-2 {
        animation-delay: 1.2s;
    }

    .hero-ampersand {
        opacity: 0;

        transform: scale(0.6);

        animation: fadeAmpersand 0.7s ease forwards;

        animation-delay: 1s;
    }

    .hero-line {
        width: 80px;

        height: 1px;

        background: white;

        margin: 2rem auto;

        transform-origin: left;

        transform: scaleX(0);

        animation: lineReveal 0.9s ease forwards;

        animation-delay: 1.9s;
    }

    .hero-subtitle {
        opacity: 0;

        letter-spacing: 0.4em;

        animation: subtitleReveal 0.8s ease forwards;

        animation-delay: 2.3s;
    }

    @keyframes revealName {
        0% {
            opacity: 0;

            clip-path: inset(0 100% 0 0);

            filter: blur(8px);

            transform: translateY(12px);
        }

        60% {
            opacity: 1;
        }

        100% {
            opacity: 1;

            clip-path: inset(0 0 0 0);

            filter: none;

            transform: none;
        }
    }

    @keyframes fadeAmpersand {
        from {
            opacity: 0;

            transform: scale(0.5);
        }

        to {
            opacity: 1;

            transform: scale(1);
        }
    }

    @keyframes lineReveal {
        from {
            transform: scaleX(0);
        }

        to {
            transform: scaleX(1);
        }
    }

    @keyframes subtitleReveal {
        from {
            opacity: 0;

            letter-spacing: 0.8em;

            transform: translateY(15px);
        }

        to {
            opacity: 1;

            letter-spacing: 0.35em;

            transform: none;
        }
    }
    .card-image,
    .card-subtitle,
    .card-title,
    .card-time,
    .card-button {
        opacity: 0;
    }

    .card-content.visible .card-image {
        animation: imageReveal 1.2s ease forwards;
    }

    .card-content.visible .card-subtitle {
        animation: textReveal 0.6s ease forwards;
        animation-delay: 0.2s;
    }

    .card-content.visible .card-title {
        animation: textReveal 0.7s ease forwards;
        animation-delay: 0.4s;
    }

    .card-content.visible .card-time {
        animation: textReveal 0.7s ease forwards;
        animation-delay: 0.6s;
    }

    .card-content.visible .card-button {
        animation: textReveal 0.7s ease forwards;
        animation-delay: 0.8s;
    }

    @keyframes imageReveal {
        from {
            opacity: 0;
            transform: scale(1.08);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    @keyframes textReveal {
        from {
            opacity: 0;
            transform: translateY(20px);
            filter: blur(5px);
        }

        to {
            opacity: 1;
            transform: none;
            filter: none;
        }
    }

    .audio-player {
        position: fixed;
        top: 8px;
        left: 50%;
        transform: translateX(-50%);
        background-color: rgba(96, 18, 18, 0.6);
        padding: 8px 16px;
        border-radius: 55px;
        display: flex;
        align-items: center;
        gap: 12px;
        width: auto;
        max-width: 320px;
        z-index: 1000;
    }

    button {
        background: none;
        border: none;
        cursor: pointer;
        padding: 4px;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
        fill: white;
        transition: fill 0.3s ease;
    }

    button:hover {
        fill: #3d0818;
    }

    svg {
        width: 20px;
        height: 20px;
    }

    .volume-slider {
        -webkit-appearance: none;
        width: 120px;
        height: 6px;
        border-radius: 12px;
        background: rgba(61, 9, 12, 0.8);
        cursor: pointer;
        position: relative;
    }

    .volume-slider::-webkit-slider-runnable-track {
        height: 6px;
        background: rgba(61, 9, 12, 0.8);
        border-radius: 12px;
    }
    .volume-slider::-moz-range-track {
        height: 6px;
        background: rgba(61, 9, 12, 0.8);
        border-radius: 12px;
    }

    .volume-slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: white;
        cursor: pointer;
        margin-top: -5px;
        box-shadow: 0 0 4px rgba(61, 9, 12, 0.8);
        transition: background-color 0.2s;
    }
    .volume-slider::-moz-range-thumb {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        background: white;
        cursor: pointer;
        box-shadow: 0 0 4px rgba(61, 9, 12, 0.8);
        transition: background-color 0.2s;
    }

    .volume-slider::-webkit-slider-thumb:hover,
    .volume-slider::-moz-range-thumb:hover {
        background-color: #301d06;
    }
</style>

