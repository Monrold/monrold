<script is:inline>
    document.querySelectorAll(".card-content").forEach((card) => {
        const observer = new IntersectionObserver(
            ([entry]) => {
                if (entry.isIntersecting) {
                    card.classList.add("visible");
                    observer.disconnect();
                }
            },
            {
                threshold: 0.4,
            },
        );

        observer.observe(card);
    });
</script>
