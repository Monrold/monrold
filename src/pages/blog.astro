---
import FilterPost from "../components/filterposts.astro";
const allPostsMd = await Astro.glob("../pages/posts/*.md");
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Document</title>
    </head>
    <body>
        <div class="h-screen">
            <FilterPost />
            <div>
                <ul>
                    {
                        allPostsMd.map((post) => {
                          return (
                            <li>
                              <a class="" href={post.url}>
                                {post.frontmatter.title}
                              </a>
                            </li>
                          );
                        })
                      }
                </ul>
            </div>
        </div>
    </body>
</html>
