<script is:inline>
const input = document.getElementById("nombreInvitado");
const boton = document.getElementById("btnWhatsapp");

const telefono = "5217717736362";

boton.addEventListener("click", () => {

    const mensaje = `Hola Itzel y Danao 👋

Mi nombre es ${input.value}.

Deseo confirmar la asistencia de mi familia a su boda. ❤️`;

    boton.href =
        `https://wa.me/${telefono}?text=${encodeURIComponent(mensaje)}`;

});
</script>
